{
  "name": "@drincs/pixi-vn",
  "version": "1.6.0",
  "type": "module",
  "description": "Pixi'VN is a npm package that provides various features for creating visual novels.",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "tsup --watch",
    "build": "tsup --config tsup.config.ts",
    "test": "vitest"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs",
      "default": "./dist/index.mjs"
    },
    "./core": {
      "types": "./dist/core.d.ts",
      "import": "./dist/core.mjs",
      "require": "./dist/core.cjs",
      "default": "./dist/core.mjs"
    },
    "./pixi.js": {
      "types": "./dist/pixi/index.d.ts",
      "import": "./dist/pixi/index.js",
      "require": "./dist/pixi/index.js",
      "default": "./dist/pixi/index.js"
    },
    "./narration": {
      "types": "./dist/narration.d.ts",
      "import": "./dist/narration.mjs",
      "require": "./dist/narration.cjs",
      "default": "./dist/narration.mjs"
    },
    "./history": {
      "types": "./dist/history.d.ts",
      "import": "./dist/history.mjs",
      "require": "./dist/history.cjs",
      "default": "./dist/history.mjs"
    },
    "./storage": {
      "types": "./dist/storage.d.ts",
      "import": "./dist/storage.mjs",
      "require": "./dist/storage.cjs",
      "default": "./dist/storage.mjs"
    },
    "./canvas": {
      "types": "./dist/canvas.d.ts",
      "import": "./dist/canvas.mjs",
      "require": "./dist/canvas.cjs",
      "default": "./dist/canvas.mjs"
    },
    "./sound": {
      "types": "./dist/sound.d.ts",
      "import": "./dist/sound.mjs",
      "require": "./dist/sound.cjs",
      "default": "./dist/sound.mjs"
    },
    "./characters": {
      "types": "./dist/characters.d.ts",
      "import": "./dist/characters.mjs",
      "require": "./dist/characters.cjs",
      "default": "./dist/characters.mjs"
    },
    "./vite": {
      "types": "./dist/vite.d.ts",
      "import": "./dist/vite.mjs",
      "require": "./dist/vite.cjs",
      "default": "./dist/vite.mjs"
    },
    "./vite-listener": {
      "types": "./dist/vite-listener.d.ts",
      "import": "./dist/vite-listener.mjs",
      "require": "./dist/vite-listener.cjs",
      "default": "./dist/vite-listener.mjs"
    },
    "./motion": {
      "types": "./dist/motion.d.ts",
      "import": "./dist/motion.mjs",
      "require": "./dist/motion.cjs",
      "default": "./dist/motion.mjs"
    }
  },
  "typesVersions": {
    "*": {
      "core": [
        "./dist/core.d.ts"
      ],
      "pixi.js": [
        "./dist/pixi.d.ts"
      ],
      "narration": [
        "./dist/narration.d.ts"
      ],
      "history": [
        "./dist/history.d.ts"
      ],
      "storage": [
        "./dist/storage.d.ts"
      ],
      "canvas": [
        "./dist/canvas.d.ts"
      ],
      "sound": [
        "./dist/sound.d.ts"
      ],
      "characters": [
        "./dist/characters.d.ts"
      ],
      "vite": [
        "./dist/vite.d.ts"
      ],
      "vite-listener": [
        "./dist/vite-listener.d.ts"
      ],
      "motion": [
        "./dist/motion.d.ts"
      ]
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DRincs-Productions/pixi-vn.git"
  },
  "author": "DRincs-Productions",
  "license": "LGPL-2.1",
  "bugs": {
    "url": "https://github.com/DRincs-Productions/pixi-vn/issues"
  },
  "homepage": "https://pixi-vn.web.app/",
  "funding": "https://github.com/DRincs-Productions/pixi-vn?sponsor=1",
  "dependencies": {
    "@pixi/devtools": "^2.0.1",
    "@pixi/sound": "^6.0.1",
    "motion": "^12.38.0",
    "pixi.js": "^8.17.1"
  },
  "peerDependencies": {
    "@pixi/devtools": "^2.0.0",
    "@pixi/sound": "^6.0.0",
    "motion": "^12.38.0",
    "pixi.js": "^8.17.0"
  },
  "devDependencies": {
    "@types/crypto-js": "^4.2.2",
    "@types/mime-db": "^1.43.6",
    "crypto-js": "^4.2.0",
    "jsdom": "^29.0.1",
    "keyv": "^5.6.0",
    "lru-cache": "^11.2.7",
    "microdiff": "^1.5.0",
    "mime-db": "^1.54.0",
    "ts-node": "^10.9.2",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vite-tsconfig-paths": "^6.0.3",
    "vitest": "^4.0.16"
  },
  "keywords": [
    "2d",
    "canvas",
    "development",
    "engine",
    "game",
    "game-development",
    "game-engine",
    "games",
    "js",
    "novel",
    "pixi",
    "pixi-js",
    "visual",
    "visual-novel",
    "webgl"
  ]
}
