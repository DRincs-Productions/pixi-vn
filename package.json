{
  "name": "@drincs/pixi-vn",
  "version": "1.8.3",
  "type": "module",
  "description": "Pixi'VN is a npm package that provides various features for creating visual novels.",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "tsup --watch",
    "build": "tsup --config tsup.config.ts",
    "lint": "biome lint",
    "check": "biome check",
    "format": "biome format --write",
    "test": "vitest",
    "docs": "typedoc"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "default": "./dist/index.js"
    },
    "./core": {
      "types": "./dist/core.d.ts",
      "import": "./dist/core.js",
      "require": "./dist/core.cjs",
      "default": "./dist/core.js"
    },
    "./pixi.js": {
      "types": "./dist/pixi/index.d.ts",
      "import": "./dist/pixi/index.js",
      "require": "./dist/pixi/index.js",
      "default": "./dist/pixi/index.js"
    },
    "./narration": {
      "types": "./dist/narration.d.ts",
      "import": "./dist/narration.js",
      "require": "./dist/narration.cjs",
      "default": "./dist/narration.js"
    },
    "./history": {
      "types": "./dist/history.d.ts",
      "import": "./dist/history.js",
      "require": "./dist/history.cjs",
      "default": "./dist/history.js"
    },
    "./storage": {
      "types": "./dist/storage.d.ts",
      "import": "./dist/storage.js",
      "require": "./dist/storage.cjs",
      "default": "./dist/storage.js"
    },
    "./canvas": {
      "types": "./dist/canvas.d.ts",
      "import": "./dist/canvas.js",
      "require": "./dist/canvas.cjs",
      "default": "./dist/canvas.js"
    },
    "./sound": {
      "types": "./dist/sound.d.ts",
      "import": "./dist/sound.js",
      "require": "./dist/sound.cjs",
      "default": "./dist/sound.js"
    },
    "./characters": {
      "types": "./dist/characters.d.ts",
      "import": "./dist/characters.js",
      "require": "./dist/characters.cjs",
      "default": "./dist/characters.js"
    },
    "./vite": {
      "types": "./dist/vite.d.ts",
      "import": "./dist/vite.js",
      "require": "./dist/vite.cjs",
      "default": "./dist/vite.js"
    },
    "./vite-listener": {
      "types": "./dist/vite-listener.d.ts",
      "import": "./dist/vite-listener.js",
      "require": "./dist/vite-listener.cjs",
      "default": "./dist/vite-listener.js"
    },
    "./motion": {
      "types": "./dist/motion.d.ts",
      "import": "./dist/motion.js",
      "require": "./dist/motion.cjs",
      "default": "./dist/motion.js"
    }
  },
  "typesVersions": {
    "*": {
      "core": [
        "./dist/core.d.ts"
      ],
      "pixi.js": [
        "./dist/pixi.d.ts"
      ],
      "narration": [
        "./dist/narration.d.ts"
      ],
      "history": [
        "./dist/history.d.ts"
      ],
      "storage": [
        "./dist/storage.d.ts"
      ],
      "canvas": [
        "./dist/canvas.d.ts"
      ],
      "sound": [
        "./dist/sound.d.ts"
      ],
      "characters": [
        "./dist/characters.d.ts"
      ],
      "vite": [
        "./dist/vite.d.ts"
      ],
      "vite-listener": [
        "./dist/vite-listener.d.ts"
      ],
      "motion": [
        "./dist/motion.d.ts"
      ]
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DRincs-Productions/pixi-vn.git"
  },
  "author": "DRincs-Productions",
  "license": "LGPL-2.1",
  "bugs": {
    "url": "https://github.com/DRincs-Productions/pixi-vn/issues"
  },
  "homepage": "https://pixi-vn.com/",
  "funding": "https://github.com/DRincs-Productions/pixi-vn?sponsor=1",
  "dependencies": {
    "@pixi/devtools": ">=2.0.0",
    "motion": ">=12.38.0",
    "pixi.js": ">=8.17.0",
    "tinyglobby": "^0.2.16",
    "tone": ">=15.1.0"
  },
  "peerDependencies": {
    "@pixi/devtools": ">=2.0.0",
    "motion": ">=12.38.0",
    "pixi.js": ">=8.17.0",
    "tone": ">=15.1.0",
    "vite": ">=5.0.0"
  },
  "peerDependenciesMeta": {
    "vite": {
      "optional": true
    }
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.12",
    "@types/crypto-js": "^4.2.2",
    "@types/mime-db": "^1.43.6",
    "crypto-js": "^4.2.0",
    "jsdom": "^29.0.2",
    "keyv": "^5.6.0",
    "lru-cache": "11.2.7",
    "microdiff": "^1.5.0",
    "mime-db": "^1.54.0",
    "picocolors": "^1.1.1",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "tsup": "^8.5.1",
    "typedoc": "^0.28.19",
    "typedoc-plugin-markdown": "^4.11.0",
    "typescript": "^5.9.3",
    "vite": "^8.0.9",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.5"
  },
  "keywords": [
    "2d",
    "canvas",
    "development",
    "engine",
    "game",
    "game-development",
    "game-engine",
    "games",
    "js",
    "novel",
    "pixi",
    "pixi-js",
    "visual",
    "visual-novel",
    "webgl"
  ]
}
